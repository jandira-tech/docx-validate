{
    "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
    "version": "0.2",
    "language": "en",
    "files": ["src/**/*.{ts,tsx,js,mjs,cjs,json,md}", "tests/**/*.{ts,tsx,js,mjs,cjs}", "*.{ts,js,json,md}"],
    "ignorePaths": [
        "node_modules/**",
        "dist/**",
        "build/**",
        "coverage/**",
        "bun.lock",
        "package-lock.json",
        "yarn.lock",
        "pnpm-lock.yaml",
        "*.docx",
        "*.xlsx",
        "*.pdf",
        "docx/**",
        "docx-templates/**",
        ".git/**",
        ".DS_Store"
    ],
    "dictionaries": ["typescript", "node", "npm", "bash", "html", "css", "filetypes", "softwareTerms"],
    "words": [
        "docx",
        "xmldom",
        "jszip",
        "libxmljs",
        "xpath",
        "ooxml",
        "openxml",
        "wordprocessingml",
        "drawingml",
        "vmlDrawing",
        "footnotes",
        "endnotes",
        "settings",
        "fonttable",
        "numbering",
        "rels",
        "schemas",
        "openxmlformats",
        "microsoft",
        "wordprocessing",
        "bumpp",
        "tsconfig",
        "vite",
        "vitest",
        "tmpdir",
        "mkdtemp",
        "unlink",
        "stat",
        "stderr",
        "stdout",
        "argv",
        "commander",
        "subcommand",
        "subcommands",
        "tempfile",
        "validator",
        "validators",
        "schemafile",
        "xsd",
        "xsds",
        "rels",
        "xmlns",
        "noNamespace",
        "targetNamespace",
        "iso",
        "ECMA",
        "ECMA376",
        "transitional",
        "strict"
    ],
    "ignoreRegExpList": ["/0x[0-9a-fA-F]+/g", "/[A-Fa-f0-9]{32,}/g", "/https?:\\/\\/[^\\s)]+/g", "/sha\\d+-[A-Za-z0-9+/=]+/g"],
    "allowCompoundWords": true
}
